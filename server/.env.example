PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://sns-tool.online

# Master Admin Account
MASTER_EMAIL=admin@example.com
MASTER_PASSWORD=your_secure_password_here

# SMTP Configuration (メール送信: 登録完了・二段階認証)
SMTP_HOST=your-smtp-server.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=your-email@example.com

# X API Configuration
X_BEARER_TOKEN=your_bearer_token

# PHP Admin Script Access Key (required for start_node.php, stop_node.php, etc.)
ADMIN_KEY=your_random_secret_key_here
